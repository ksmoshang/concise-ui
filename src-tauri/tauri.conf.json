{
  "productName": "concise ui",
  "version": "1.0.0",
  "identifier": "com.jianglin.conciseui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "concise ui",
        "width": 800,
        "height": 600,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "center": true,
        "visible": false 
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
    
      
    }
  
}